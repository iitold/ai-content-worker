# AI Content Worker — Environment Config
# Copy this file to .env and fill in your actual keys

# === REQUIRED ===

# Gemini AI — get free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase — get from: Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...your_anon_key_here

# === OPTIONAL ===

# OpenAI fallback (leave blank to use Gemini only)
OPENAI_API_KEY=

# How often to check for new jobs (ms). Default: 30000 (30s)
POLL_INTERVAL_MS=30000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
